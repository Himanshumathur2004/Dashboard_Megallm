# AI Generation

# MegaLLM gateway (used by tools/devto-assistant, tools/reddit-assistant, pipeline)
# If you see 401 AUTH_FAILED / "API key is revoked", mint a new key in the MegaLLM dashboard.
MEGALLM_API_KEY=
MEGALLM_BASE_URL=https://ai.megallm.io/v1
MODEL=

# Hacker News assistant (tools/hackernews-assistant) — optional; uses MegaLLM above for drafting
# HN_LIST=top                          # Story list: top, new, or best
# HN_ID_FETCH_LIMIT=80                 # How many story IDs to check
# HN_MIN_SCORE=8                       # Minimum upvotes to include
# HN_MAX_COMMENTS=500                  # Skip threads with >500 comments
# HN_MAX_STORIES=30                    # Max stories to fetch (default: 30)
# HN_STRICT_TOPIC=false                # Set to true for AI/LLM ONLY; false (default) includes all + boosts AI/LLM topics
# HN_ASSISTANT_PORT=3458               # Dashboard port

# Bluesky assistant (tools/bluesky-assistant) — public API for fetch; MegaLLM for drafts
# BSKY_FEED_URI=at://did:plc:z72i7hdynmk6r22z27h6tvur/app.bsky.feed.generator/whats-hot
# BSKY_MAX_POSTS=35
# BSKY_MIN_LIKES=15
# BSKY_PUBLIC_API=https://public.api.bsky.app

# X (Twitter) Assistant (tools/x-assistant) — X Scraper API for fetch; MegaLLM for drafts
# Get API key: https://api.xscraper.io (free tier available)
X_SCRAPER_API_KEY=                      # Required for fetching tweets from X Scraper API
X_SCRAPER_API_URL=http://localhost:3005 # Optional: custom X Scraper API endpoint
# X_ASSISTANT_PORT=3459                 # Optional: standalone dashboard port

# Unified dashboard — Reddit, Dev.to, HN, Bluesky (`npm run assistant:unified` from repo root)
# UNIFIED_ASSISTANT_USER=
# UNIFIED_ASSISTANT_PASSWORD=
# UNIFIED_SESSION_SECRET=change-me-in-production
# UNIFIED_ASSISTANT_PORT=3500

# Web Scraping
FIRECRAWL_API_KEY=

# SERP Tracking (free tier: 2500 queries/mo)
SERPER_API_KEY=

# Social Metrics (read-only, ~$0.15/1K tweets)
TWITTERAPI_IO_KEY=

# Dev.to (free API)
DEVTO_API_KEY=
DEVTO_USERNAME=
DEVTO_PUBLISH_IMMEDIATELY=true
DEVTO_DEFAULT_TAGS=megallm,viral,trending

# Google Search Console
GOOGLE_SERVICE_ACCOUNT_JSON=
GSC_SITE_URL=https://megallm.io

# Vercel Cron Auth
CRON_SECRET=

# Pipeline Control
PIPELINE_ENABLED=true
PIPELINE_DRY_RUN=false
