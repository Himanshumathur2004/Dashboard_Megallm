# ============================================================================
# UNIFIED DASHBOARD - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values
# ============================================================================

# ============================================================================
# MEGALLM API (Required for both Blog and Comment generation)
# ============================================================================
# Get your API key from https://beta.megallm.io
MEGALLM_API_KEY=sk-mega-YOUR_API_KEY_HERE
MEGALLM_BASE_URL=https://beta.megallm.io/v1
MODEL=claude-opus-4-6

# ============================================================================
# MONGODB (Required for Blog Dashboard)
# ============================================================================
# MongoDB Atlas (Cloud) - Recommended:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/megallm_blog_platform?retryWrites=true&w=majority
#
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017
MONGODB_URI=
MONGODB_DB=megallm_blog_platform

# ============================================================================
# OPENAI API (Optional - for Comment Dashboard)
# ============================================================================
OPENAI_API_KEY=

# ============================================================================
# FIRECRAWL (Optional - for web scraping)
# ============================================================================
FIRECRAWL_API_KEY=

# ============================================================================
# SOCIAL PLATFORMS (Optional)
# ============================================================================
DEVTO_API_KEY=
DEVTO_USERNAME=
SERPER_API_KEY=